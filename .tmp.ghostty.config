# Ghostty config for macOS (developer-focused, minimal overrides)
# Active theme:
theme = Flexoki Light
# Alternatives (uncomment one to switch):
# theme = Rose Pine Dawn
# theme = Catppuccin Latte
# theme = GitHub Light High Contrast
font-family = Menlo
font-size = 22
window-padding-x = 10
window-padding-y = 10
window-save-state = always
window-inherit-working-directory = true
window-inherit-font-size = true
scrollback-limit = 200000
mouse-hide-while-typing = true
macos-option-as-alt = left
shell-integration = detect
shell-integration-features = cursor,no-sudo,title,ssh-env,no-ssh-terminfo,path
copy-on-select = true
clipboard-paste-protection = true
confirm-close-surface = true

# AI coding workflow
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s
tab-inherit-working-directory = true
split-inherit-working-directory = true

# Tab naming for agent workflows
keybind = super+alt+t=prompt_tab_title
